        {
          "id": "g5x_u5",
          "name": "分数除法",
          "formulas": [
            {
              "id": "f016",
              "title": "分数除以整数",
              "latex": "\\frac{a}{b} \\div c = \\frac{a}{bc}",
              "text": "(a/b) ÷ c = a/(b×c)",
              "html": "<span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">b</span></span> ÷ c = <span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">b×c</span></span>",
              "rules": ["分子不变", "分母乘以除数", "等于乘以除数的倒数"],
              "related_topics": ["分数除以整数", "分数除法", "分数除法应用题"],
              "example": "2/3 ÷ 4 = 2/12 = 1/6",
              "tip": "÷整数 = ×整数的倒数"
            },
            {
              "id": "f017",
              "title": "整数除以分数",
              "latex": "a \\div \\frac{b}{c} = a \\times \\frac{c}{b}",
              "text": "a ÷ (b/c) = a × (c/b)",
              "html": "a ÷ <span class=\"formula-frac\"><span class=\"num\">b</span><span class=\"den\">c</span></span> = a × <span class=\"formula-frac\"><span class=\"num\">c</span><span class=\"den\">b</span></span>",
              "rules": ["除以一个分数", "等于乘这个分数的倒数", "颠倒分子分母"],
              "related_topics": ["整数除以分数", "分数除法", "分数除法应用题"],
              "example": "6 ÷ 2/3 = 6 × 3/2 = 9",
              "tip": "÷分数 = ×倒数（翻转）"
            },
            {
              "id": "f018",
              "title": "分数除以分数",
              "latex": "\\frac{a}{b} \\div \\frac{c}{d} = \\frac{a}{b} \\times \\frac{d}{c}",
              "text": "(a/b) ÷ (c/d) = (a/b) × (d/c)",
              "html": "<span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">b</span></span> ÷ <span class=\"formula-frac\"><span class=\"num\">c</span><span class=\"den\">d</span></span> = <span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">b</span></span> × <span class=\"formula-frac\"><span class=\"num\">d</span><span class=\"den\">c</span></span>",
              "rules": ["除以一个分数", "等于乘它的倒数", "把除号变乘号，除数颠倒"],
              "related_topics": ["分数除以分数", "分数除法", "分数除法应用题"],
              "example": "3/4 ÷ 2/5 = 3/4 × 5/2 = 15/8",
              "tip": "除号变乘号，后面分数上下翻转"
            },
            {
              "id": "f019",
              "title": "除法与倒数",
              "latex": "a \\div b = a \\times \\frac{1}{b}",
              "text": "a ÷ b = a × (1/b)",
              "html": "a ÷ b = a × <span class=\"formula-frac\"><span class=\"num\">1</span><span class=\"den\">b</span></span>",
              "rules": ["除以一个数等于乘它的倒数", "这是分数除法的核心", "0没有倒数"],
              "related_topics": ["倒数", "分数除法"],
              "example": "8 ÷ 4 = 8 × 1/4 = 2",
              "tip": "除法的本质就是乘倒数"
            },
            {
              "id": "f020",
              "title": "倒数的定义",
              "latex": "\\frac{a}{b} \\times \\frac{b}{a} = 1",
              "text": "(a/b) × (b/a) = 1",
              "html": "<span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">b</span></span> × <span class=\"formula-frac\"><span class=\"num\">b</span><span class=\"den\">a</span></span> = 1",
              "rules": ["互为倒数的两个数相乘等于1", "分子分母颠倒就是倒数", "1的倒数是1，0没有倒数"],
              "related_topics": ["倒数", "分数除法"],
              "example": "3/5的倒数是5/3，因为3/5×5/3=1",
              "tip": "分子分母互换位置"
            }
          ]
        },
