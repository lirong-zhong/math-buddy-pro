              "latex": "S = 6a^2",
              "text": "S = 6×棱长²",
              "html": "S = 6a<sup>2</sup>",
              "rules": ["6个面完全相同", "每面都是正方形", "6×棱长×棱长"],
              "related_topics": ["表面积", "展开图", "长方体（一）"],
              "example": "棱长3cm → S=6×9=54cm²",
              "tip": "6个相同的正方形面"
            }
          ]
        },
        {
          "id": "g5x_u3",
          "name": "分数乘法",
          "formulas": [
            {
              "id": "f008",
              "title": "分数乘整数",
              "latex": "\\frac{a}{b} \\times c = \\frac{ac}{b}",
              "text": "(a/b) × c = ac/b",
              "html": "<span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">b</span></span> × c = <span class=\"formula-frac\"><span class=\"num\">a×c</span><span class=\"den\">b</span></span>",
              "rules": ["分子乘整数", "分母不变", "能约分先约分再乘"],
              "related_topics": ["分数乘整数", "分数乘法", "分数乘法应用题"],
              "example": "2/3 × 4 = 8/3 = 2又2/3",
              "tip": "分子×整数，分母不变"
            },
            {
              "id": "f009",
              "title": "分数乘分数",
              "latex": "\\frac{a}{b} \\times \\frac{c}{d} = \\frac{ac}{bd}",
              "text": "(a/b) × (c/d) = ac/bd",
              "html": "<span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">b</span></span> × <span class=\"formula-frac\"><span class=\"num\">c</span><span class=\"den\">d</span></span> = <span class=\"formula-frac\"><span class=\"num\">a×c</span><span class=\"den\">b×d</span></span>",
              "rules": ["分子×分子", "分母×分母", "先约分再乘更简便"],
              "related_topics": ["分数乘分数", "分数乘法", "分数乘法应用题"],
              "example": "2/3 × 3/5 = 6/15 = 2/5",
              "tip": "分子乘分子，分母乘分母，先约分更简便"
            },
            {
              "id": "f010",
              "title": "求一个数的几分之几",
              "latex": "\\text{部分量} = \\text{单位1} \\times \\frac{a}{b}",
              "text": "部分量 = 单位1 × (a/b)",
              "html": "部分量 = 单位\"1\" × <span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">b</span></span>",
              "rules": ["找出单位\"1\"", "用乘法计算", "谁的几分之几，谁就是单位1"],
              "related_topics": ["分数乘法应用题", "分数乘法"],
              "example": "全班40人，男生占3/5，男生=40×3/5=24人",
              "tip": "关键词「的」前面是单位1"
            },
            {
              "id": "f011",
              "title": "连续分数乘法",
              "latex": "\\frac{a}{b} \\times \\frac{c}{d} \\times \\frac{e}{f} = \\frac{ace}{bdf}",
              "text": "(a/b) × (c/d) × (e/f) = ace/bdf",
              "html": "<span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">b</span></span> × <span class=\"formula-frac\"><span class=\"num\">c</span><span class=\"den\">d</span></span> × <span class=\"formula-frac\"><span class=\"num\">e</span><span class=\"den\">f</span></span> = <span class=\"formula-frac\"><span class=\"num\">a×c×e</span><span class=\"den\">b×d×f</span></span>",
              "rules": ["所有分子相乘", "所有分母相乘", "先交叉约分再乘"],
              "related_topics": ["分数乘法", "分数乘分数"],
              "example": "1/2 × 2/3 × 3/4 = 6/24 = 1/4",
              "tip": "可以交叉约分，更快更简便"
            }
          ]
        },
