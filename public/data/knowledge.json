        {
          "id": "g5x_u1",
          "name": "分数加减法",
          "formulas": [
            {
              "id": "f001",
              "title": "同分母分数加法",
              "latex": "\\frac{a}{c}+\\frac{b}{c}=\\frac{a+b}{c}",
              "text": "a/c + b/c = (a+b)/c",
              "html": "<span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">c</span></span> + <span class=\"formula-frac\"><span class=\"num\">b</span><span class=\"den\">c</span></span> = <span class=\"formula-frac\"><span class=\"num\">a+b</span><span class=\"den\">c</span></span>",
              "rules": ["分母不变", "分子相加", "结果能约分要约分"],
              "related_topics": ["同分母分数加减法", "分数加减法"],
              "example": "1/4 + 2/4 = 3/4",
              "tip": "分母相同，直接加分子"
            },
            {
              "id": "f002",
              "title": "同分母分数减法",
              "latex": "\\frac{a}{c}-\\frac{b}{c}=\\frac{a-b}{c}",
              "text": "a/c - b/c = (a-b)/c",
              "html": "<span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">c</span></span> − <span class=\"formula-frac\"><span class=\"num\">b</span><span class=\"den\">c</span></span> = <span class=\"formula-frac\"><span class=\"num\">a−b</span><span class=\"den\">c</span></span>",
              "rules": ["分母不变", "分子相减", "结果能约分要约分"],
              "related_topics": ["同分母分数加减法", "分数加减法"],
              "example": "5/6 - 2/6 = 3/6 = 1/2",
              "tip": "分母相同，直接减分子"
            },
            {
              "id": "f003",
              "title": "异分母分数加减法",
              "latex": "\\frac{a}{b}\\pm\\frac{c}{d}=\\frac{ad\\pm bc}{bd}",
              "text": "a/b ± c/d → 先通分，再加减",
              "html": "<span class=\"formula-frac\"><span class=\"num\">a</span><span class=\"den\">b</span></span> ± <span class=\"formula-frac\"><span class=\"num\">c</span><span class=\"den\">d</span></span> → 先通分再计算",
              "rules": ["先找最小公倍数通分", "再按同分母规则加减", "结果要约分"],
              "related_topics": ["异分母分数加减法", "分数加减法", "分数加减混合运算"],
              "example": "1/3 + 1/4 = 4/12 + 3/12 = 7/12",
              "tip": "不同分母先通分，变成同分母再算"
            }
          ]
        },
        {
          "id": "g5x_u2",
          "name": "长方体（一）",
          "formulas": [
