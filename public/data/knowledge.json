              "title": "正方体棱长总和",
              "latex": "L = 12a",
              "text": "L = 12×棱长",
              "html": "L = 12a",
              "rules": ["正方体有12条棱", "每条棱都相等", "直接12×棱长"],
              "related_topics": ["长方体正方体的认识", "表面积", "长方体（一）"],
              "example": "棱长5cm → L=12×5=60cm",
              "tip": "12条一样长的棱"
            },
            {
              "id": "f006",
              "title": "长方体表面积",
              "latex": "S = 2(ab+ah+bh)",
              "text": "S = 2×(长×宽 + 长×高 + 宽×高)",
              "html": "S = 2(ab + ah + bh)",
              "rules": ["6个面分3对", "对面面积相等", "2×(上面+前面+侧面)"],
