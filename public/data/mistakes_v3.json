{
  "version": "3.0",
  "mistakes": [
    {
      "id": "MK-001",
      "name": "符号错误",
      "category": "计算类",
      "grade_range": [
        "7",
        "8",
        "9"
      ],
      "description": "去括号时符号处理错误",
      "typical_error": "-(a-b) 错写为 -a-b",
      "correct": "-(a-b) = -a+b",
      "prevention_tip": "去括号口诀：括号前是减号，括号里面变个号",
      "related_knowledge": [
        "KN-G7S-008"
      ],
      "frequency": "high"
    },
    {
      "id": "MK-002",
      "name": "绝对值理解错误",
      "category": "概念类",
      "grade_range": [
        "7",
        "8",
        "9"
      ],
      "description": "对绝对值几何意义和分类讨论理解不到位",
      "typical_error": "|x|=x（未考虑x<0的情况）",
      "correct": "|x|=x(x>=0), |x|=-x(x<0)",
      "prevention_tip": "绝对值表示到原点的距离，距离永远是非负的",
      "related_knowledge": [
        "KN-G7S-001"
      ],
      "frequency": "high"
    },
    {
      "id": "MK-003",
      "name": "移项变号遗忘",
      "category": "计算类",
      "grade_range": [
        "7",
        "8",
        "9"
      ],
      "description": "解方程移项时忘记变号",
      "typical_error": "2x+3=7 → 2x=7+3=10",
      "correct": "2x+3=7 → 2x=7-3=4 → x=2",
      "prevention_tip": "移项=搬家+变号，搬过等号必须变号",
      "related_knowledge": [
        "KN-G7S-010"
      ],
      "frequency": "high"
    },
    {
      "id": "MK-004",
      "name": "同类项合并错误",
      "category": "计算类",
      "grade_range": [
        "7",
        "8"
      ],
      "description": "误将不同类项合并或合并时指数相加",
      "typical_error": "3x^2+2x=5x^3",
      "correct": "3x^2+2x 不能合并（不是同类项）",
      "prevention_tip": "同类项条件：字母相同，对应字母的指数也相同",
      "related_knowledge": [
        "KN-G7S-007"
      ],
      "frequency": "medium"
    },
    {
      "id": "MK-005",
      "name": "分数运算错误",
      "category": "计算类",
      "grade_range": [
        "6",
        "7",
        "8"
      ],
      "description": "异分母分数加减时分子分母同时相加",
      "typical_error": "1/2+1/3=2/5",
      "correct": "1/2+1/3=3/6+2/6=5/6",
      "prevention_tip": "异分母加减必须先通分",
      "related_knowledge": [
        "KN-G6X-006"
      ],
      "frequency": "high"
    },
    {
      "id": "MK-006",
      "name": "二次函数顶点公式错误",
      "category": "公式类",
      "grade_range": [
        "9"
      ],
      "description": "混淆顶点式中h的符号",
      "typical_error": "y=(x-3)^2+2的顶点是(-3,2)",
      "correct": "y=(x-3)^2+2的顶点是(3,2)",
      "prevention_tip": "y=a(x-h)^2+k中，顶点横坐标和括号内符号相反",
      "related_knowledge": [
        "KN-G9S-006"
      ],
      "frequency": "high"
    },
    {
      "id": "MK-007",
      "name": "圆面积与周长混淆",
      "category": "公式类",
      "grade_range": [
        "6",
        "7"
      ],
      "description": "混淆圆的面积公式和周长公式",
      "typical_error": "圆面积=2*pi*r",
      "correct": "圆面积=pi*r^2, 圆周长=2*pi*r",
      "prevention_tip": "面积看面(pi*r^2有平方=面)；周长看线(2*pi*r)",
      "related_knowledge": [
        "KN-G6X-001"
      ],
      "frequency": "medium"
    },
    {
      "id": "MK-008",
      "name": "概率分母错误",
      "category": "概念类",
      "grade_range": [
        "9"
      ],
      "description": "求概率时等可能事件总数计算错误",
      "typical_error": "掷两枚硬币P(两正)=1/3",
      "correct": "P(两正)=1/4（共4种：正正、正反、反正、反反）",
      "prevention_tip": "列树状图或列表，确保列出所有等可能结果",
      "related_knowledge": [
        "KN-G9S-014"
      ],
      "frequency": "high"
    },
    {
      "id": "MK-009",
      "name": "相似比与面积比混淆",
      "category": "概念类",
      "grade_range": [
        "9"
      ],
      "description": "混淆相似比k和面积比k^2",
      "typical_error": "相似比为2:3, 则面积比为2:3",
      "correct": "相似比为2:3, 则面积比为4:9",
      "prevention_tip": "线性比k, 面积比k^2, 体积比k^3",
      "related_knowledge": [
        "KN-G9S-009"
      ],
      "frequency": "medium"
    },
    {
      "id": "MK-010",
      "name": "不等式方向变化",
      "category": "计算类",
      "grade_range": [
        "7",
        "8",
        "9"
      ],
      "description": "不等式两边乘除负数时忘记变号",
      "typical_error": "-2x>6 → x>-3",
      "correct": "-2x>6 → x<-3（除以-2要变号）",
      "prevention_tip": "乘除负数必须变号！可以标记提醒自己",
      "related_knowledge": [
        "KN-G7X-005"
      ],
      "frequency": "high"
    },
    {
      "id": "MK-011",
      "name": "分式有意义条件遗漏",
      "category": "概念类",
      "grade_range": [
        "8",
        "9"
      ],
      "description": "忘记分式分母不能为零的条件",
      "typical_error": "y=1/(x-2)的定义域是全体实数",
      "correct": "y=1/(x-2)的定义域是x!=2",
      "prevention_tip": "遇到分式第一件事：令分母!=0",
      "related_knowledge": [
        "KN-G8S-007"
      ],
      "frequency": "medium"
    },
    {
      "id": "MK-012",
      "name": "一元二次方程漏解",
      "category": "计算类",
      "grade_range": [
        "9"
      ],
      "description": "解一元二次方程时只求一个根",
      "typical_error": "x^2=4 → x=2",
      "correct": "x^2=4 → x=2 或 x=-2",
      "prevention_tip": "平方=正数有两个解（一正一负），别忘记正负号",
      "related_knowledge": [
        "KN-G9S-002"
      ],
      "frequency": "high"
    },
    {
      "id": "MK-013",
      "name": "去括号错误",
      "category": "计算类",
      "grade_range": [
        "7",
        "8",
        "9"
      ],
      "description": "括号前是减号时，去括号后各项变号错误",
      "typical_error": "-(a-b+c) 错写为 -a-b+c",
      "correct": "-(a-b+c) = -a+b-c",
      "prevention_tip": "口诀：括号前是减号，去掉括号变个号（每一项都要变）",
      "related_knowledge": [
        "KN-G7S-003"
      ],
      "frequency": "high"
    },
    {
      "id": "MK-014",
      "name": "移项错误",
      "category": "计算类",
      "grade_range": [
        "7",
        "8",
        "9"
      ],
      "description": "移项时忘记变号",
      "typical_error": "2x+3=7 → 2x=7+3=10",
      "correct": "2x+3=7 → 2x=7-3=4 → x=2",
      "prevention_tip": "移项口诀：从等号一边移到另一边，加变减、减变加、乘变除、除变乘",
      "related_knowledge": [
        "KN-G7S-004"
      ],
      "frequency": "high"
    },
    {
      "id": "MK-015",
      "name": "同类项错误",
      "category": "计算类",
      "grade_range": [
        "7",
        "8",
        "9"
      ],
      "description": "合并同类项时搞错什么是同类项，或系数运算错误",
      "typical_error": "3a²b + 2ab² 误认为同类项合并为 5a²b",
      "correct": "3a²b 和 2ab² 不是同类项（字母相同但指数不同），不能合并",
      "prevention_tip": "同类项三要素：①字母相同 ②每个字母的指数相同 ③与系数和排列顺序无关",
      "related_knowledge": [
        "KN-G7S-003"
      ],
      "frequency": "high"
    }
  ]
}